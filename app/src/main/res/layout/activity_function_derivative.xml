<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".FunctionDerivativeActivity">

    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="返回主页"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="函数微分计算器"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_weight="1" />

    </LinearLayout>

    <EditText
        android:id="@+id/etFunctionInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="输入函数表达式 (如: sin(x), x^2, exp(x))"
        android:inputType="text"
        app:layout_constraintEnd_toStartOf="@+id/btnCalculate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llHeader" />

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="计算"
        app:layout_constraintBaseline_toBaselineOf="@id/etFunctionInput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/etFunctionInput" />

    <!-- 函数示例 - 使用横向滚动 -->
    <HorizontalScrollView
        android:id="@+id/hsvExamples"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etFunctionInput">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExample1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="sin(x)" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExample2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="x^2 + 2*x" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExample3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="log(x)" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExample4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="exp(x)" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExample5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="cos(x) * x" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 定义域设置 -->
    <LinearLayout
        android:id="@+id/llDomainSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hsvExamples">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="定义域:"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etXMin"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:hint="X最小"
            android:inputType="numberDecimal|numberSigned"
            android:text="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 到 "
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <EditText
            android:id="@+id/etXMax"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:hint="X最大"
            android:inputType="numberDecimal|numberSigned"
            android:text="10" />

        <Button
            android:id="@+id/btnApplyDomain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="应用"
            style="?attr/materialButtonOutlinedStyle" />

    </LinearLayout>

    <!-- 函数和微分结果显示 -->
    <LinearLayout
        android:id="@+id/llResults"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llDomainSettings">

        <TextView
            android:id="@+id/tvOriginalFunction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#e3f2fd"
            android:padding="8dp"
            android:text="原函数: "
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDerivativeFunction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#fff3e0"
            android:padding="8dp"
            android:text="微分函数: "
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- 显示控制选项 -->
        <LinearLayout
            android:id="@+id/llDisplayControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="显示:"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupDisplay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:singleSelection="false"
                app:selectionRequired="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipShowOriginal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="原函数"
                    android:checkable="true"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipShowDerivative"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="微分函数"
                    android:checkable="true"
                    android:checked="true" />

            </com.google.android.material.chip.ChipGroup>

            <Button
                android:id="@+id/btnUpdateChart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="更新图表"
                style="?attr/materialButtonOutlinedStyle" />

        </LinearLayout>

    </LinearLayout>

    <!-- 图表显示区域 -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/chart"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llResults" />

</androidx.constraintlayout.widget.ConstraintLayout>
